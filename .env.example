# Copy this file to .env and fill in your credentials.
# .env is gitignored — never commit it.

# ── Primary DB (RDS / Aalind user) ────────────────────────────────────────────
DB_HOST=your-rds-endpoint.us-east-1.rds.amazonaws.com
DB_PORT=3306
DB_USER=your_db_user
DB_PASSWORD=your_db_password

# ── RDS Admin user (Biogen scripts) ───────────────────────────────────────────
DB_ADMIN_HOST=your-rds-endpoint.us-east-1.rds.amazonaws.com
DB_ADMIN_PORT=3306
DB_ADMIN_USER=admin
DB_ADMIN_PASSWORD=your_admin_password

# ── Internal on-prem DB (nd-root-mysql) ───────────────────────────────────────
DB_INTERNAL_HOST=your-internal-host-ip
DB_INTERNAL_PORT=3306
DB_INTERNAL_USER=nd-root-mysql
DB_INTERNAL_PASSWORD=your_internal_password

# ── Sudha user ────────────────────────────────────────────────────────────────
DB_SUDHA_USER=sudha
DB_SUDHA_PASSWORD=your_sudha_password
